# Copie para .env (cp .env.example .env). O Docker Compose lê este arquivo automaticamente.

# PostgreSQL
POSTGRES_DB=erp
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp
POSTGRES_PORT=5432

# Portas das aplicações
BACKEND_PORT=8080
FRONTEND_PORT=4200

# Portas de observability
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200

# Grafana admin (POC)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# App security (auth/JWT)
APP_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
APP_CORS_ORIGIN=http://localhost:4200
APP_COOKIE_SECURE=false

# Versão da aplicação (SemVer) — exibida na tela; sobrescreve o default do compose/app
APP_VERSION=0.12.0
